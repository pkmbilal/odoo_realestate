<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="realestate.RealestateDashboardAction" owl="1">
        <div class="o_realestate_dashboard_app">
            <t t-if="state.loading">
                <div class="o_realestate_dashboard_loading">
                    <div class="o_realestate_dashboard_loading_card">
                        Loading dashboard...
                    </div>
                </div>
            </t>
            <t t-elif="state.error">
                <div class="alert alert-danger o_realestate_dashboard_error" role="alert">
                    <t t-out="state.error"/>
                </div>
            </t>
            <t t-else="">
                <div class="o_realestate_dashboard">
                    <section class="o_realestate_dashboard_hero">
                        <div class="o_realestate_dashboard_eyebrow">Portfolio overview</div>
                        <div class="o_realestate_dashboard_title_row">
                            <h1 class="o_realestate_dashboard_title">Realestate Dashboard</h1>
                            <div class="o_realestate_dashboard_company">
                                <span>Company</span>
                                <strong><t t-out="companyName"/></strong>
                            </div>
                        </div>
                        <p class="o_realestate_dashboard_subtitle">
                            Track occupancy, rent flow, and portfolio activity from one operational screen.
                        </p>
                    </section>

                    <section class="o_realestate_dashboard_actions" aria-label="Primary navigation">
                        <button type="button" t-on-click="openBuildings" class="o_realestate_dashboard_action">
                            <span class="o_realestate_dashboard_action_label">Properties</span>
                            <span class="o_realestate_dashboard_action_value"><i class="fa fa-building"/>Buildings</span>
                        </button>
                        <button type="button" t-on-click="openUnits" class="o_realestate_dashboard_action">
                            <span class="o_realestate_dashboard_action_label">Inventory</span>
                            <span class="o_realestate_dashboard_action_value"><i class="fa fa-home"/>Units</span>
                        </button>
                        <button type="button" t-on-click="openTenants" class="o_realestate_dashboard_action">
                            <span class="o_realestate_dashboard_action_label">People</span>
                            <span class="o_realestate_dashboard_action_value"><i class="fa fa-user"/>Tenants</span>
                        </button>
                        <button type="button" t-on-click="openContracts" class="o_realestate_dashboard_action">
                            <span class="o_realestate_dashboard_action_label">Leases</span>
                            <span class="o_realestate_dashboard_action_value"><i class="fa fa-file-text-o"/>Contracts</span>
                        </button>
                        <button type="button" t-on-click="openInvoices" class="o_realestate_dashboard_action">
                            <span class="o_realestate_dashboard_action_label">Revenue</span>
                            <span class="o_realestate_dashboard_action_value"><i class="fa fa-money"/>Invoices</span>
                        </button>
                        <button t-if="state.isAdmin" type="button" t-on-click="openSettings" class="o_realestate_dashboard_action">
                            <span class="o_realestate_dashboard_action_label">Setup</span>
                            <span class="o_realestate_dashboard_action_value"><i class="fa fa-cog"/>Settings</span>
                        </button>
                    </section>

                    <section class="o_realestate_dashboard_stats">
                        <button type="button" t-on-click="openBuildings" class="o_realestate_dashboard_stat o_realestate_dashboard_stat--accent">
                            <span class="o_realestate_dashboard_stat_title">Buildings <i class="fa fa-building"/></span>
                            <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.building_count || 0"/></span>
                            <span class="o_realestate_dashboard_stat_meta">Managed buildings in the active company</span>
                        </button>
                        <button type="button" t-on-click="openUnits" class="o_realestate_dashboard_stat">
                            <span class="o_realestate_dashboard_stat_title">Units <i class="fa fa-home"/></span>
                            <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.unit_count || 0"/></span>
                            <span class="o_realestate_dashboard_stat_meta">All rentable units and rooms</span>
                        </button>
                        <button type="button" t-on-click="openActiveContracts" class="o_realestate_dashboard_stat">
                            <span class="o_realestate_dashboard_stat_title">Active contracts <i class="fa fa-file-text-o"/></span>
                            <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.active_contract_count || 0"/></span>
                            <span class="o_realestate_dashboard_stat_meta">Currently running rental agreements</span>
                        </button>
                        <button type="button" t-on-click="openTenants" class="o_realestate_dashboard_stat">
                            <span class="o_realestate_dashboard_stat_title">Tenants <i class="fa fa-user"/></span>
                            <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.tenant_count || 0"/></span>
                            <span class="o_realestate_dashboard_stat_meta">Tenant contacts in the portfolio</span>
                        </button>
                        <button type="button" t-on-click="openDueInvoices" class="o_realestate_dashboard_stat">
                            <span class="o_realestate_dashboard_stat_title">Open invoices <i class="fa fa-money"/></span>
                            <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.invoice_due_count || 0"/></span>
                            <span class="o_realestate_dashboard_stat_meta">Unpaid rent invoices not overdue</span>
                        </button>
                    </section>

                    <section class="o_realestate_dashboard_panels">
                        <div class="o_realestate_dashboard_panel">
                            <h2>Occupancy</h2>
                            <div class="row g-3">
                                <div class="col-12 col-md-4">
                                    <div class="o_realestate_dashboard_stat">
                                        <span class="o_realestate_dashboard_stat_title">Available <i class="fa fa-check-circle"/></span>
                                        <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.available_unit_count || 0"/></span>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="o_realestate_dashboard_stat">
                                        <span class="o_realestate_dashboard_stat_title">Occupied <i class="fa fa-lock"/></span>
                                        <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.occupied_unit_count || 0"/></span>
                                    </div>
                                </div>
                                <div class="col-12 col-md-4">
                                    <div class="o_realestate_dashboard_stat">
                                        <span class="o_realestate_dashboard_stat_title">Maintenance <i class="fa fa-wrench"/></span>
                                        <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.maintenance_unit_count || 0"/></span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_realestate_dashboard_panel_actions">
                                <button type="button" t-on-click="openAvailableUnits" class="o_realestate_dashboard_link">Available units</button>
                                <button type="button" t-on-click="openOccupiedUnits" class="o_realestate_dashboard_link">Occupied units</button>
                                <button type="button" t-on-click="openFloors" class="o_realestate_dashboard_link">Floors</button>
                            </div>
                        </div>

                        <div class="o_realestate_dashboard_panel">
                            <h2>Rent Flow</h2>
                            <div class="row g-3">
                                <div class="col-12 col-md-6">
                                    <div class="o_realestate_dashboard_stat">
                                        <span class="o_realestate_dashboard_stat_title">Due <i class="fa fa-bell"/></span>
                                        <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.invoice_due_count || 0"/></span>
                                        <span class="o_realestate_dashboard_stat_meta">Ready to collect</span>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6">
                                    <div class="o_realestate_dashboard_stat">
                                        <span class="o_realestate_dashboard_stat_title">Overdue <i class="fa fa-exclamation-triangle"/></span>
                                        <span class="o_realestate_dashboard_stat_value"><t t-out="dashboard.invoice_overdue_count || 0"/></span>
                                        <span class="o_realestate_dashboard_stat_meta">Needs follow-up</span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_realestate_dashboard_panel_actions">
                                <button type="button" t-on-click="openDueInvoices" class="o_realestate_dashboard_link">Due invoices</button>
                                <button type="button" t-on-click="openOverdueInvoices" class="o_realestate_dashboard_link">Overdue invoices</button>
                                <button type="button" t-on-click="openContracts" class="o_realestate_dashboard_link">Contracts</button>
                            </div>
                        </div>

                    </section>
                </div>
            </t>
        </div>
    </t>
</templates>
