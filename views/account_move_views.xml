<odoo>
    <record id="view_move_form_realestate" model="ir.ui.view">
        <field name="name">account.move.form.realestate</field><field name="model">account.move</field><field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_origin']" position="after">
                <field name="realestate_contract_id" invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="rental_period_start" invisible="not realestate_contract_id"/>
                <field name="rental_period_end" invisible="not realestate_contract_id"/>
            </xpath>
        </field>
    </record>
    <record id="action_realestate_invoice" model="ir.actions.act_window">
        <field name="name">Rent Invoices</field><field name="res_model">account.move</field><field name="view_mode">tree,form</field><field name="domain">[('realestate_contract_id','!=',False),('move_type','=','out_invoice')]</field><field name="context">{'default_move_type':'out_invoice'}</field>
    </record>
</odoo>
