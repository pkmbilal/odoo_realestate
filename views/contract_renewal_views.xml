<odoo>
    <record id="view_realestate_contract_renewal_wizard_form" model="ir.ui.view">
        <field name="name">realestate.contract.renewal.wizard.form</field>
        <field name="model">realestate.contract.renewal.wizard</field>
        <field name="arch" type="xml">
            <form string="Renew Contract">
                <sheet>
                    <group>
                        <group string="Current Contract">
                            <field name="contract_id" readonly="1"/>
                            <field name="current_start_date" readonly="1"/>
                            <field name="current_end_date" readonly="1"/>
                            <field name="current_payment_cycle" readonly="1"/>
                            <field name="current_rent_amount" readonly="1"/>
                            <field name="current_deposit_amount" readonly="1"/>
                        </group>
                        <group string="Renewal Terms">
                            <field name="new_end_date"/>
                            <field name="payment_cycle"/>
                            <field name="rent_amount"/>
                            <field name="deposit_amount"/>
                            <field name="next_invoice_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="renewal_notes" placeholder="Optional renewal notes for the contract chatter."/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" type="object" string="Renew" class="oe_highlight"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
