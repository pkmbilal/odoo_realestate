<odoo>
    <record id="res_config_settings_view_form_realestate" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.realestate</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Realestate" name="realestate" groups="base.group_system">
                    <block title="Saudi Rent VAT" name="realestate_saudi_vat">
                        <setting string="Residential Exempt Tax" help="Tax used for residential rent invoices.">
                            <field name="realestate_residential_tax_id" options="{'no_create': True}"/>
                        </setting>
                        <setting string="Commercial VAT Tax" help="Tax used for commercial rent invoices; configure the applicable Saudi VAT tax during onboarding.">
                            <field name="realestate_commercial_tax_id" options="{'no_create': True}"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

    <record id="action_realestate_settings" model="ir.actions.act_window">
        <field name="name">Realestate Settings</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">inline</field>
        <field name="context">{'module': 'realestate'}</field>
    </record>
</odoo>
