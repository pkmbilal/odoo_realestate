<odoo>
    <record id="module_category_realestate" model="ir.module.category">
        <field name="name">Realestate</field>
        <field name="sequence">35</field>
    </record>

    <record id="group_realestate_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="realestate.module_category_realestate"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_invoice'))]"/>
    </record>

    <record id="group_realestate_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="realestate.module_category_realestate"/>
        <field name="implied_ids" eval="[(4, ref('realestate.group_realestate_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_admin'))]"/>
    </record>

    <record id="building_company_rule" model="ir.rule">
        <field name="name">Buildings by company</field>
        <field name="model_id" ref="model_realestate_building"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('realestate.group_realestate_user'))]"/>
    </record>
    <record id="floor_company_rule" model="ir.rule">
        <field name="name">Floors by company</field>
        <field name="model_id" ref="model_realestate_floor"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('realestate.group_realestate_user'))]"/>
    </record>
    <record id="unit_company_rule" model="ir.rule">
        <field name="name">Units by company</field>
        <field name="model_id" ref="model_realestate_unit"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('realestate.group_realestate_user'))]"/>
    </record>
    <record id="contract_company_rule" model="ir.rule">
        <field name="name">Contracts by company</field>
        <field name="model_id" ref="model_realestate_contract"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('realestate.group_realestate_user'))]"/>
    </record>
    <record id="unit_history_company_rule" model="ir.rule">
        <field name="name">Unit history by company</field>
        <field name="model_id" ref="model_realestate_unit_history"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('realestate.group_realestate_user'))]"/>
    </record>
</odoo>
